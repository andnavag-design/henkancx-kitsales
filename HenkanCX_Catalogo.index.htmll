<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HenkanCX — Catálogo de Soluciones</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:#f5f6f8;color:#0D1B2A;}

.shell{display:flex;min-height:100vh;}

/* SIDEBAR */
.sidebar{width:240px;min-width:240px;background:#0D1B2A;display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;overflow-y:auto;}
.logo-area{padding:22px 20px 18px;border-bottom:1px solid rgba(255,255,255,0.08);}
.logo-area img{height:28px;display:block;}
.logo-text{font-family:'Segoe UI',sans-serif;font-weight:700;font-size:18px;color:#fff;letter-spacing:-0.3px;}

.group-label{font-size:9px;font-weight:700;letter-spacing:0.14em;color:rgba(203,108,230,0.65);text-transform:uppercase;padding:18px 20px 6px;}

.nav-item{display:flex;align-items:center;gap:11px;padding:10px 20px;cursor:pointer;border-left:3px solid transparent;transition:background 0.15s;text-decoration:none;}
.nav-item:hover{background:rgba(255,255,255,0.05);}
.nav-item.active{background:rgba(203,108,230,0.13);border-left-color:#CB6CE6;}
.nav-icon{width:18px;height:18px;flex-shrink:0;opacity:0.4;}
.nav-item.active .nav-icon{opacity:1;color:#CB6CE6;}
.nav-item.active .nav-icon svg path,.nav-item.active .nav-icon svg rect,.nav-item.active .nav-icon svg circle,.nav-item.active .nav-icon svg polyline,.nav-item.active .nav-icon svg line,.nav-item.active .nav-icon svg ellipse{stroke:#CB6CE6;}
.nav-label{font-size:12px;color:rgba(255,255,255,0.5);line-height:1.3;}
.nav-item.active .nav-label{color:#fff;font-weight:600;}

.sidebar-footer{margin-top:auto;padding:18px 20px;border-top:1px solid rgba(255,255,255,0.08);}
.sidebar-footer .name{font-size:12px;font-weight:600;color:rgba(255,255,255,0.75);margin-bottom:4px;}
.sidebar-footer .detail{font-size:11px;color:rgba(255,255,255,0.35);line-height:1.7;}
.sidebar-footer a{color:#CB6CE6;text-decoration:none;}

/* MAIN */
.main{margin-left:240px;flex:1;min-height:100vh;}
.panel{display:none;}
.panel.active{display:block;}

/* PANEL HEADER */
.panel-header{background:#0D1B2A;padding:32px 40px 28px;border-bottom:3px solid #CB6CE6;}
.eyebrow{font-size:10px;font-weight:700;letter-spacing:0.14em;color:#CB6CE6;text-transform:uppercase;margin-bottom:8px;}
.panel-title{font-size:26px;font-weight:700;color:#fff;margin-bottom:10px;line-height:1.2;}
.panel-tagline{font-size:13.5px;color:#a0aec0;line-height:1.7;max-width:600px;}

/* PANEL BODY */
.panel-body{padding:32px 40px;}

.section-title{font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#CB6CE6;margin-bottom:16px;margin-top:28px;}
.section-title:first-child{margin-top:0;}

/* USE CASES GRID */
.use-cases{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
.use-case{background:#fff;border:1px solid #e8e8f0;border-radius:10px;padding:14px 16px;display:flex;gap:12px;align-items:flex-start;}
.use-case-icon{width:34px;height:34px;min-width:34px;background:#0D1B2A;border-radius:8px;display:flex;align-items:center;justify-content:center;}
.use-case-icon svg{width:18px;height:18px;}
.use-case-icon svg *{stroke:#CB6CE6;}
.uc-name{font-size:12.5px;font-weight:600;color:#0D1B2A;margin-bottom:3px;}
.uc-desc{font-size:11.5px;color:#4A4E69;line-height:1.5;}

/* BENEFITS */
.benefits{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
.benefit{display:flex;align-items:flex-start;gap:9px;font-size:12.5px;color:#4A4E69;line-height:1.5;}
.benefit-icon{width:16px;height:16px;min-width:16px;margin-top:1px;}
.benefit-icon svg *{stroke:#CB6CE6;}

/* METRICS */
.metrics{display:flex;gap:12px;}
.metric{flex:1;background:#0D1B2A;border-radius:10px;padding:18px 14px;text-align:center;}
.metric-num{font-size:22px;font-weight:700;color:#CB6CE6;display:block;margin-bottom:5px;}
.metric-label{font-size:11px;color:#a0b0c0;line-height:1.4;}
.metric-source{font-size:10.5px;color:#8fa8c0;margin-top:5px;font-weight:500;}

/* TAGS */
.tags{display:flex;flex-wrap:wrap;gap:8px;}
.tag{background:#F0E9FB;color:#534AB7;font-size:11.5px;font-weight:500;padding:5px 14px;border-radius:999px;border:1px solid #d4b8f5;}

/* DIVIDER */
.divider{border:none;border-top:1px solid #f0f0f0;margin:24px 0;}

/* CTA */
.cta{background:#F0E9FB;border:1px solid #d4b8f5;border-radius:10px;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;margin-top:28px;}
.cta-text{font-size:13px;color:#3C3489;}
.cta-text span{color:#833AE0;font-weight:600;}
.cta-btn{background:#833AE0;color:#fff;font-size:12.5px;font-weight:600;padding:9px 20px;border-radius:8px;border:none;cursor:pointer;white-space:nowrap;}
.cta-btn:hover{background:#6B2EBF;}

.clients-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.client-card{background:#fff;border:1px solid #e8e8f0;border-radius:12px;padding:20px 18px;display:flex;flex-direction:column;gap:11px;}
.client-card:hover{border-color:#d4b8f5;}
.client-logo-wrap{height:72px;display:flex;align-items:center;justify-content:center;background:#f9f9fb;border-radius:8px;padding:10px 14px;}
.client-logo-wrap img{max-height:52px;max-width:100%;object-fit:contain;}
.client-sector{display:flex;}
.sector-pill{background:#F0E9FB;color:#534AB7;font-size:11px;font-weight:600;padding:3px 12px;border-radius:999px;border:1px solid #d4b8f5;}
.client-product{font-size:12.5px;font-weight:600;color:#0D1B2A;}
.client-result{font-size:11.5px;color:#CB6CE6;font-weight:500;display:flex;align-items:flex-start;gap:5px;line-height:1.4;}
.client-result::before{content:"↑";font-size:12px;flex-shrink:0;}


.cases-list{display:flex;flex-direction:column;gap:32px;}
.case-card{background:#fff;border:1px solid #e8e8f0;border-radius:14px;overflow:hidden;}
.case-card-header{background:#0D1B2A;padding:20px 24px;display:flex;align-items:center;gap:20px;}
.case-logo-wrap{width:90px;height:52px;background:#fff;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:6px 10px;flex-shrink:0;}
.case-logo-wrap img{max-height:40px;max-width:80px;object-fit:contain;}
.case-header-info{flex:1;}
.case-client-name{font-size:15px;font-weight:700;color:#fff;margin-bottom:3px;}
.case-meta{display:flex;gap:10px;flex-wrap:wrap;}
.case-meta-pill{font-size:10.5px;font-weight:600;padding:2px 10px;border-radius:999px;}
.case-meta-sector{background:rgba(203,108,230,0.18);color:#CB6CE6;border:1px solid rgba(203,108,230,0.3);}
.case-meta-product{background:rgba(131,58,224,0.15);color:#a87ef5;border:1px solid rgba(131,58,224,0.25);}
.case-body{padding:24px;}
.case-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
.case-block-title{font-size:9.5px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#CB6CE6;margin-bottom:8px;}
.case-block-text{font-size:12.5px;color:#4A4E69;line-height:1.65;}
.case-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px;}
.case-metric{background:#0D1B2A;border-radius:10px;padding:14px 12px;text-align:center;}
.case-metric-num{font-family:'Segoe UI',sans-serif;font-size:20px;font-weight:700;color:#CB6CE6;display:block;margin-bottom:4px;}
.case-metric-label{font-size:10.5px;color:#a0b0c0;line-height:1.4;}
.case-quote{background:#F8F5FE;border-left:3px solid #CB6CE6;border-radius:0 8px 8px 0;padding:14px 18px;margin-top:4px;}
.case-quote-text{font-size:12.5px;color:#3C3489;line-height:1.65;font-style:italic;margin-bottom:6px;}
.case-quote-author{font-size:11px;font-weight:600;color:#833AE0;}


.tab-btns{display:flex;gap:8px;margin-bottom:24px;}
.tab-btn{padding:8px 20px;border-radius:8px;border:1px solid #e8e8f0;background:#fff;font-size:12.5px;font-weight:600;color:#4A4E69;cursor:pointer;transition:all 0.15s;}
.tab-btn.active{background:#0D1B2A;color:#fff;border-color:#0D1B2A;}

.sector-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.sector-card{border:1px solid #e8e8f0;border-radius:12px;overflow:hidden;background:#fff;}
.sector-card-head{padding:14px 18px;display:flex;align-items:center;gap:12px;}
.sector-icon{width:36px;height:36px;min-width:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;}
.sector-icon svg{width:18px;height:18px;}
.sector-name{font-size:13.5px;font-weight:700;color:#0D1B2A;}
.sector-body{padding:0 18px 16px;}
.sector-products{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;}
.sector-product-row{display:flex;align-items:flex-start;gap:10px;}
.sp-badge{background:#F0E9FB;color:#534AB7;font-size:10.5px;font-weight:600;padding:2px 10px;border-radius:999px;border:1px solid #d4b8f5;white-space:nowrap;flex-shrink:0;margin-top:1px;}
.sp-pain{font-size:11.5px;color:#4A4E69;line-height:1.4;}
.sector-transversal{background:#0D1B2A;border-radius:8px;padding:10px 14px;margin-top:4px;}
.st-label{font-size:9.5px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#CB6CE6;margin-bottom:5px;}
.st-tags{display:flex;flex-wrap:wrap;gap:5px;}
.st-tag{font-size:10.5px;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);padding:2px 8px;border-radius:999px;}
.sector-opener{border-top:1px solid #f0f0f0;padding-top:10px;margin-top:10px;font-size:11.5px;color:#833AE0;font-style:italic;line-height:1.5;}
.sector-opener::before{content:'"';margin-right:2px;}
.sector-opener::after{content:'"';margin-left:2px;}

.product-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.product-card{border:1px solid #e8e8f0;border-radius:12px;overflow:hidden;background:#fff;}
.product-card.transversal{border-color:#CB6CE6;border-width:2px;}
.product-card-head{background:#0D1B2A;padding:14px 18px;display:flex;align-items:center;gap:12px;}
.product-card-head.transversal-head{background:linear-gradient(135deg,#1a0533,#0D1B2A);}
.pc-icon{width:34px;height:34px;min-width:34px;background:rgba(203,108,230,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;}
.pc-icon svg{width:17px;height:17px;}
.pc-name{font-size:12.5px;font-weight:700;color:#fff;line-height:1.3;}
.pc-body{padding:14px 18px;}
.pc-sector-label{font-size:9.5px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#CB6CE6;margin-bottom:8px;}
.pc-sectors{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;}
.pc-sector-pill{background:#F0E9FB;color:#534AB7;font-size:10.5px;font-weight:500;padding:3px 10px;border-radius:999px;border:1px solid #d4b8f5;}
.pc-sector-pill.all{background:#0D1B2A;color:#CB6CE6;border-color:rgba(203,108,230,0.4);}
.pc-profile-label{font-size:9.5px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#CB6CE6;margin-bottom:5px;}
.pc-profile{font-size:11.5px;color:#4A4E69;line-height:1.5;}
.transversal-banner{background:#0D1B2A;border-radius:8px;padding:10px 14px;margin-top:10px;display:flex;gap:8px;align-items:flex-start;}
.transversal-banner svg{width:16px;height:16px;flex-shrink:0;margin-top:1px;}
.transversal-banner-text{font-size:11.5px;color:#CB6CE6;line-height:1.5;font-style:italic;}

</style>
</head>
<body>
<div class="shell">

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="logo-area">
    <img src="https://www.henkancx.com/logo-henkancx.png" alt="HenkanCX"
      onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
    <span class="logo-text" style="display:none">henkancx</span>
  </div>

  <div class="group-label">Inicio</div>
  <a class="nav-item active" onclick="show('clientes',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
    <span class="nav-label">Nuestros Clientes</span>
  </a>

  <a class="nav-item" onclick="show('casos',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></span>
    <span class="nav-label">Casos de Éxito</span>
  </a>

  <a class="nav-item" onclick="show('tabla',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg></span>
    <span class="nav-label">¿Qué le ofrezco?</span>
  </a>

  <div class="group-label">Comunicación &amp; CX</div>
  <a class="nav-item" onclick="show('chatbot',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg></span>
    <span class="nav-label">Agentes Conversacionales IA</span>
  </a>
  <a class="nav-item" onclick="show('cc',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg></span>
    <span class="nav-label">Contact Center CX 2.0</span>
  </a>
  <a class="nav-item" onclick="show('crm',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
    <span class="nav-label">CRM — Gestión de Clientes</span>
  </a>

  <div class="group-label">Inspecciones</div>
  <a class="nav-item" onclick="show('snnapi',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></span>
    <span class="nav-label">Snnapi — Inspecciones IA</span>
  </a>
  <a class="nav-item" onclick="show('teleinspect',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></span>
    <span class="nav-label">TeleInspect Suite</span>
  </a>

  <div class="group-label">Verticales</div>
  <a class="nav-item" onclick="show('sifed',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg></span>
    <span class="nav-label">SIFED — Deportivo</span>
  </a>
  <a class="nav-item" onclick="show('ganadero',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16s-1-1.5 0-3 2-2 2-4V8a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1c0 2 1 3 2 4s0 3 0 3"/><path d="M9 21v-4a3 3 0 0 1 6 0v4"/><path d="M4 16h16"/></svg></span>
    <span class="nav-label">GanaderoAI</span>
  </a>

  <div class="group-label">Tecnología</div>
  <a class="nav-item" onclick="show('automatizacion',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></span>
    <span class="nav-label">Automatización &amp; Desarrollo</span>
  </a>
  <a class="nav-item" onclick="show('it',this)">
    <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg></span>
    <span class="nav-label">Administración de IT</span>
  </a>

  <div class="sidebar-footer">
    <div class="name">Samanta Velandria</div>
    <div class="detail">+1 829 551 7804<br><a href="mailto:info@henkancx.com">info@henkancx.com</a><br>henkancx.com</div>
  </div>
</div>

<!-- MAIN CONTENT -->
<div class="main">


<!-- CLIENTES -->
<div class="panel active" id="p-clientes">
  <div class="panel-header">
    <div class="eyebrow">Portafolio de clientes</div>
    <div class="panel-title">Empresas que ya confían en HenkanCX</div>
    <div class="panel-tagline">Más de 5 años transformando operaciones en múltiples sectores de Latinoamérica.</div>
  </div>
  <div class="panel-body">
    <div class="section-title">Nuestros clientes</div>
    <div class="clients-grid">

      <div class="client-card">
        <div class="client-logo-wrap"><img src="data:image/png;base64," alt="La Regional de Seguros"></div>
        <div class="client-sector"><span class="sector-pill">Seguros</span></div>
        <div class="client-product">Snnapi — Inspecciones IA</div>
        <div class="client-result">95% reducción en tiempos de inspección</div>
      </div>

      <div class="client-card">
        <div class="client-logo-wrap"><img src="data:image/png;base64," alt="ASSA Seguros"></div>
        <div class="client-sector"><span class="sector-pill">Seguros</span></div>
        <div class="client-product">Snnapi — Inspecciones IA</div>
        <div class="client-result">53% reducción de costos operativos</div>
      </div>

      <div class="client-card">
        <div class="client-logo-wrap"><img src="data:image/png;base64," alt="Phoenix Tower International"></div>
        <div class="client-sector"><span class="sector-pill">Telecom</span></div>
        <div class="client-product">TeleInspect Suite</div>
        <div class="client-result">99% trazabilidad de órdenes de trabajo en campo</div>
      </div>

      <div class="client-card">
        <div class="client-logo-wrap"><img src="data:image/png;base64," alt="Grand Deli Gourmet"></div>
        <div class="client-sector"><span class="sector-pill">Retail / Food</span></div>
        <div class="client-product">Chatbot + WhatsApp</div>
        <div class="client-result">80%+ CSAT en canales automatizados</div>
      </div>

      <div class="client-card">
        <div class="client-logo-wrap"><img src="data:image/png;base64," alt="Nisato"></div>
        <div class="client-sector"><span class="sector-pill">Soporte Técnico</span></div>
        <div class="client-product">Chatbot + WhatsApp</div>
        <div class="client-result">-40% carga operativa en atención al cliente</div>
      </div>

      <div class="client-card">
        <div class="client-logo-wrap"><img src="data:image/png;base64," alt="Mystic"></div>
        <div class="client-sector"><span class="sector-pill">Soporte Técnico</span></div>
        <div class="client-product">Chatbot + WhatsApp</div>
